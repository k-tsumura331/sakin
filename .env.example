# データ本体の置き場所。実テーマ・生成JSONL・SQLite本体はここに置き、リポジトリには含めない
SAKIN_HOME=~/sakin-data

# LLM呼び出しバックエンド: claude-cli(デフォルト) | anthropic-api
SAKIN_LLM_BACKEND=claude-cli

# anthropic-api バックエンド利用時のみ必要
ANTHROPIC_API_KEY=

# generate(生成)/evaluate(評価)ロールに使うモデルの上書き(任意)
# claude-cli向け: SAKIN_CLI_MODEL_GENERATE / SAKIN_CLI_MODEL_EVALUATE (デフォルト: haiku / sonnet)
# anthropic-api向け: SAKIN_MODEL_GENERATE / SAKIN_MODEL_EVALUATE (デフォルト: claude-haiku-4-5 / claude-sonnet-5)

# 1 か true でLLM呼び出しをモック応答に差し替える(実課金・実利用枠を消費しない)
SAKIN_DRY_RUN=

# 人間評価の記録名(evaluations.evaluator = human:<この値>)
SAKIN_HUMAN_NAME=

# Web UIのbindアドレス。未設定なら起動時にTailscaleインターフェースを検出し、
# 見つからなければ 127.0.0.1 にフォールバックする
SAKIN_BIND_ADDRESS=
